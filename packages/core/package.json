{
  "name": "@bullfighting/core",
  "version": "0.1.0",
  "description": "斗牛(抢庄斗牛)规则引擎:洗牌、评牌、比牌、结算。纯函数,零运行时依赖。",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "vitest": "^2.1.8"
  }
}

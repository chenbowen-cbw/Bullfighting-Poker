{
  "name": "@bullfighting/stats",
  "version": "0.1.0",
  "description": "结算落库的纯逻辑:从对局结算上下文推导 rounds/round_players/user_stats 写入载荷。框架无关,可独立单测。",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@bullfighting/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "vitest": "^2.1.8"
  }
}
